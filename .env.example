TELEGRAM_BOT_TOKEN=replace-with-bot-token-from-botfather
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=sinegu_db
DB_PORT=3306

# Channel/chat to publish to. @username for public channels, or numeric -100... id.
TELEGRAM_CHANNEL_ID=@sinegualnews

# Timezone for daily/weekly/monthly boundaries and the schedule
TIMEZONE=Asia/Manila

# Anthropic model
ANTHROPIC_MODEL=claude-haiku-4-5

# Operational stream cron knobs (set to 0 or blank to disable that job)
EXPOSURE_HOURS=6          # post current exposure snapshot every N hours
STRATEGY_DAYS=7           # weekly strategy summary window (Sunday 20:00 anchor)

# Admin allowlist — comma-separated Telegram user IDs that can run admin
# commands (/broadcast, /draft, /ask, /dryrun, /force_*, /reload_env).
# Each staff member can get theirs by sending /whoami to the bot.
TELEGRAM_ADMIN_USER_IDS=

# Where scheduled posts get sent for approval. With this set, NOTHING
# auto-publishes to TELEGRAM_CHANNEL_ID — every scheduled draft lands here
# with Approve/Regenerate/Discard buttons. Use the admin group's /chatid.
# Leave blank to keep legacy direct-publish behavior.
TELEGRAM_ADMIN_CHAT_ID=

# Knowledge-of-the-day post hour (0–23, Manila time). Set to -1 to disable.
# Reads docs/*.pdf and docs/daily.md for brand-voice context.
KNOWLEDGE_HOUR=9
